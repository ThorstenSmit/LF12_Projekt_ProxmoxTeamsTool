{
  "name": "proxmox-teams-tool",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"npx tsx bridge/index.ts\"",
    "dev:frontend": "vite",
    "dev:bridge": "npx tsx bridge/index.ts",
    "build": "tsc -b && vite build",
    "build:bridge": "tsc -p bridge/tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "preview": "vite preview",
    "start:bridge": "node bridge/dist/index.js"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.6.3",
    "@azure/msal-react": "^5.2.1",
    "@microsoft/teams-js": "^2.52.0",
    "@novnc/novnc": "^1.7.0",
    "@types/ws": "^8.18.1",
    "axios": "^1.15.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.1",
    "react-simple-keyboard": "^3.8.218",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.7"
  },
  "optionalDependencies": {
    "@rolldown/binding-darwin-arm64": "^1.0.0",
    "@rolldown/binding-darwin-x64": "^1.0.0",
    "@rolldown/binding-linux-arm64-gnu": "^1.0.0",
    "@rolldown/binding-linux-x64-gnu": "^1.0.0",
    "@rolldown/binding-win32-x64-msvc": "^1.0.0"
  }
}
