{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/config.js",
      "/*.{svg,png,jpg,jpeg,gif,ico,webp,css,js,mjs,map,json,txt,webmanifest,woff,woff2,ttf,eot}"
    ]
  },
  "routes": [
    {
      "route": "/config.js",
      "headers": {
        "Cache-Control": "no-store"
      }
    }
  ],
  "mimeTypes": {
    ".json": "application/json"
  }
}
