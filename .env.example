# ── Azure AD / Microsoft Entra ID App Registration ────────────────────────────
# Available to both frontend (VITE_ prefix) and the Bridge.
VITE_AZURE_CLIENT_ID=your-client-id-here
VITE_AZURE_TENANT_ID=your-tenant-id-here

# ── Bridge-Origin fuer das Frontend ───────────────────────────────────────────
# Absolute Basis-URL der Bridge (API + VNC-WebSocket).
#   leer    -> relative Pfade (/api, /ws): Frontend + Bridge teilen sich eine
#              Origin (npm run dev / Single-Host-Compose hinter Reverse-Proxy).
#   gesetzt -> z.B. https://api.example.org: Frontend (z.B. Azure Static Web
#              Apps) und Bridge (z.B. Cloudflare-Tunnel) liegen getrennt. Dann
#              auf der Bridge CORS_ALLOWED_ORIGINS setzen.
# Build-Zeit (Vite/SWA): VITE_API_BASE_URL. Container-Laufzeit (Entrypoint ->
# /config.js): API_BASE_URL. Beide leer lassen fuer den same-origin-Fall.
# VITE_API_BASE_URL=
# API_BASE_URL=

# ── Bridge ────────────────────────────────────────────────────────────────────
# Mirror of the values above (the bridge reads either form).
AZURE_CLIENT_ID=your-client-id-here
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_SECRET=your-client-secret-here

# Expected audience claim in inbound access tokens.
# Defaults to api://<AZURE_CLIENT_ID> if not set — set explicitly if you
# configured a custom Application ID URI in Entra.
# API_AUDIENCE=api://your-client-id-here

PORT=3001

# Wie der Bridge-Host-Port veroeffentlicht wird (docker-compose.backend.yml).
#   leer/Default -> 127.0.0.1:3001 (nur Loopback; der Cloudflare-Tunnel ist der
#                   eigentliche Ingress, keine LAN-Exposition).
#   gesetzt      -> z.B. 0.0.0.0:3001 fuer einen Reverse-Proxy auf einem anderen Host.
# BRIDGE_BIND=127.0.0.1:3001

# CORS: welche Frontend-Origins duerfen die Bridge cross-origin aufrufen.
#   leer    -> offen (alle Origins) — ok fuer Dev / Single-Host (same-origin).
#   gesetzt -> Komma-separierte Whitelist, noetig wenn das Frontend auf einer
#              anderen Origin liegt (z.B. Azure Static Web Apps). Beispiel:
# CORS_ALLOWED_ORIGINS=https://my-app.azurestaticapps.net,https://pttool.example.org

# How the bridge derives roles + classes for an authenticated user.
#   standard — App Roles (Proxmox.Admin/Teacher/Student) + M365-Group memberships
#   edu      — Microsoft Education Graph (/education/me, /education/me/classes)
#   auto     — probes /education/me on first request per user, falls back to
#              standard on 403/404. Recommended default.
AUTH_MODE=auto

# ── Proxmox ───────────────────────────────────────────────────────────────────
# Source-of-truth fuer Templates + VMs + Klassen-Whitelist via Tags.
# Token erzeugen im Proxmox-WebUI: Datacenter -> Permissions -> API Tokens.
# Privilege Separation für Dev ausschalten; Prod auf dedizierten User mit
# minimal noetigen Rechten (PVEVMAdmin auf Pool/Resource) eingrenzen.
# PROXMOX_URL=https://proxmox.local:8006
# PROXMOX_TOKEN_ID=user@pve!tokenname
# PROXMOX_TOKEN_SECRET=
#
# Self-signed Cert ueberspringen — only set to "false" in dev. Prod sollte
# einen vertrauenswuerdigen Cert haben.
# PROXMOX_TLS_REJECT_UNAUTHORIZED=true

# ── Cloudflare Tunnel (optional, fuer den Prod-Betrieb der Bridge) ────────────
# Token aus dem Cloudflare-Zero-Trust-Dashboard (Networks -> Tunnels -> Create).
# Wird vom cloudflared-Service in docker-compose.backend.yml gelesen (als
# TUNNEL_TOKEN). Nur noetig, wenn der Tunnel aktiv ist:
#   docker compose -f docker-compose.backend.yml --profile tunnel up -d --build
# Die Public-Hostname-Route (z.B. api.example.org -> http://bridge:3001) wird im
# Dashboard gesetzt, nicht hier. Dieselbe URL gehoert dann als VITE_API_BASE_URL
# in den Frontend-Build (SWA) und die SWA-Origin in CORS_ALLOWED_ORIGINS oben.
# CF_TUNNEL_TOKEN=

# ── Secrets statt Klartext (optional, fuer Prod / Docker) ─────────────────────
# Jeder Wert kann auch aus einer DATEI kommen: setze <NAME>_FILE auf einen Pfad
# (z.B. ein Docker-/Compose-Secret unter /run/secrets/...), dann liest die Bridge
# den Wert daraus. Funktioniert fuer Bridge UND Frontend-Container. Die direkte
# Env-Var hat Vorrang vor der Datei. Beispiel:
#   AZURE_CLIENT_SECRET_FILE=/run/secrets/azure_client_secret
#   PROXMOX_TOKEN_SECRET_FILE=/run/secrets/proxmox_token_secret
# Siehe docker-compose.yml (auskommentierter `secrets:`-Block).
