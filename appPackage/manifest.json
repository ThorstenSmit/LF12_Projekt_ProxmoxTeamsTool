{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.20/MicrosoftTeams.schema.json",
  "manifestVersion": "1.20",
  "version": "0.1.0",
  "id": "{{AZURE_CLIENT_ID}}",
  "developer": {
    "name": "LF12 Projekt Team",
    "websiteUrl": "https://{{FRONTEND_HOST}}",
    "privacyUrl": "https://{{FRONTEND_HOST}}/privacy",
    "termsOfUseUrl": "https://{{FRONTEND_HOST}}/terms"
  },
  "name": {
    "short": "Proxmox Teams Tool",
    "full": "Proxmox Management Tool for Microsoft Teams"
  },
  "description": {
    "short": "Manage Proxmox VE from Microsoft Teams",
    "full": "Microsoft-Teams-Tab fuer das Verwalten von Proxmox-VMs aus Templates. Lehrer weisen Templates Klassen zu, Schueler erstellen daraus eigene VMs und steuern sie (Start/Stop/Console)."
  },
  "icons": {
    "outline": "outline.png",
    "color": "color.png"
  },
  "accentColor": "#6264a7",
  "staticTabs": [
    {
      "entityId": "dashboard",
      "name": "Proxmox",
      "contentUrl": "https://{{FRONTEND_HOST}}/",
      "websiteUrl": "https://{{FRONTEND_HOST}}/",
      "scopes": ["personal"]
    },
    {
      "entityId": "templates",
      "name": "Templates",
      "contentUrl": "https://{{FRONTEND_HOST}}/templates",
      "websiteUrl": "https://{{FRONTEND_HOST}}/templates",
      "scopes": ["personal"]
    },
    {
      "entityId": "vms",
      "name": "Meine VMs",
      "contentUrl": "https://{{FRONTEND_HOST}}/my-vms",
      "websiteUrl": "https://{{FRONTEND_HOST}}/my-vms",
      "scopes": ["personal"]
    }
  ],
  "permissions": ["identity"],
  "validDomains": ["{{FRONTEND_HOST}}"],
  "webApplicationInfo": {
    "id": "{{AZURE_CLIENT_ID}}",
    "resource": "api://{{AZURE_CLIENT_ID}}"
  }
}
